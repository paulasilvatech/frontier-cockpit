# macOS
.DS_Store

# Local editor and test scratch
.playwright-mcp/
node_modules/
local-otel/frontend/**/node_modules/

# Frontier dashboard build artifacts
local-otel/frontend/**/dist/
local-otel/frontend/**/*.tsbuildinfo

# Workshop participant identity (local only, never commit personal values)
local-otel/client.env
local-otel/workshop.env

# Frontier Cockpit local runtime state
local-otel/.venv/
local-otel/**/*.log
local-otel/**/*-log.txt
local-otel/*.out
local-otel/*.err
local-otel/**/*.err
local-otel/materialized-traces.json
local-otel/frontier-insights.duckdb
local-otel/frontier-otel-export.duckdb
local-otel/agent-host-traces/
local-otel/*agent-traces*.db
local-otel/*agent-traces*.sqlite
local-otel/workspaces/

# Local Azure and GitHub state, secrets, and exports
local-otel/azure/.env
local-otel/azure/*state*.json
local-otel/azure/*token*
local-otel/azure/audit-storage-*.txt
local-otel/github-enterprise/*.json
local-otel/github-orgs/*.json

# Docker/generated runtime files
local-otel/stack/aspire-api-key.env
local-otel/stack/**/*.db
local-otel/stack/**/data/

# Migration backups kept local only
_archive/

# Personal marketing decks (not part of client product)
decks/

# Real secret env files (templates .example are tracked)
local-otel/azure/github-enterprise-audit-log-streaming.env
local-otel/stack/.env

# Python bytecode cache
__pycache__/
*.pyc
