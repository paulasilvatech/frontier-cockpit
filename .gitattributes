# Normalize line endings so shell scripts copied into Docker images stay LF
# even on Windows checkouts (core.autocrlf=true would otherwise break the
# zsh entrypoints inside the Alpine containers with CRLF errors).
* text=auto

*.sh text eol=lf
*.zsh text eol=lf
*.bash text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
*.bicep text eol=lf
*.bicepparam text eol=lf

# PowerShell is happiest with CRLF on Windows.
*.ps1 text eol=crlf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.duckdb binary
