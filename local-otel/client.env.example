# Frontier Cockpit Local client bootstrap configuration
#
# Copy this file to client.env and edit the values before running the client
# bootstrap. The client.env file is local-only and gitignored.
#
# macOS or Linux:
#   cp local-otel/client.env.example local-otel/client.env
#   bash local-otel/client-bootstrap.sh
#
# Windows PowerShell:
#   Copy-Item local-otel/client.env.example local-otel/client.env
#   pwsh -ExecutionPolicy Bypass -File local-otel/client-bootstrap.ps1

# Shown in the local dashboard chrome.
FRONTIER_PARTICIPANT_NAME="Client Developer"
FRONTIER_PARTICIPANT_ROLE="Developer"
FRONTIER_PARTICIPANT_EMAIL=""
FRONTIER_PARTICIPANT_TEAM=""
FRONTIER_CUSTOMER_NAME="Client Organization"
FRONTIER_DASHBOARD_TITLE="Frontier Cockpit Local"

# GitHub Copilot plan and local AI Credits budget configuration.
# Leave FRONTIER_AI_CREDITS_MONTHLY_ALLOWANCE blank to derive the shared pool
# from plan and seat count. Local telemetry is an operational estimate, not
# official GitHub billing.
FRONTIER_COPILOT_PLAN="business"
FRONTIER_COPILOT_SEATS="1"
FRONTIER_AI_CREDITS_USE_PROMO="false"
FRONTIER_AI_CREDITS_MONTHLY_ALLOWANCE=""

# VS Code channels to configure. Supported values: stable, insiders.
FRONTIER_VSCODE_CHANNELS="stable,insiders"

# Local content capture can include prompts, file paths, tool arguments, and
# tool results. The privacy-first default is false. Set true only for trusted
# local workshops or explicitly approved demos, and set it back to false after.
FRONTIER_ENABLE_CONTENT_CAPTURE="false"