<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.frontier.copilot-otel-model-registry</string>
    <key>ProgramArguments</key>
    <array>
      <string>__LOCAL_OTEL_DIR__/seed-model-multipliers.sh</string>
      <string>--quiet</string>
    </array>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true />
    <key>StandardOutPath</key>
    <string>__LOCAL_OTEL_DIR__/launchagent-model-registry.log</string>
    <key>StandardErrorPath</key>
    <string>__LOCAL_OTEL_DIR__/launchagent-model-registry.err</string>
  </dict>
</plist>
