<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.frontier.copilot-otel-daily-rollup</string>
    <key>ProgramArguments</key>
    <array>
      <string>__LOCAL_OTEL_DIR__/daily-rollup.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>RunAtLoad</key>
    <true />
    <key>StandardOutPath</key>
    <string>__LOCAL_OTEL_DIR__/launchagent-daily-rollup.log</string>
    <key>StandardErrorPath</key>
    <string>__LOCAL_OTEL_DIR__/launchagent-daily-rollup.err</string>
  </dict>
</plist>