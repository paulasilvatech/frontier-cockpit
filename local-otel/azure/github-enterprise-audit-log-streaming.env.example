# GitHub Enterprise audit log streaming to Azure Blob Storage.
# Copy this file to github-enterprise-audit-log-streaming.env and fill in your
# own values. The real .env is gitignored and must never be committed.
#
# Generate a container-scoped SAS URL with least privilege and a short expiry.
# Prefer a user delegation SAS backed by Microsoft Entra ID over an account key.

AZURE_AUDIT_STORAGE_ACCOUNT=yourstorageaccount
AZURE_AUDIT_STORAGE_CONTAINER=github-audit-logs
AZURE_AUDIT_CONTAINER_SAS_URL=https://yourstorageaccount.blob.core.windows.net/github-audit-logs?REPLACE_WITH_SAS_TOKEN
AZURE_AUDIT_BLOB_SAS_URL=https://yourstorageaccount.blob.core.windows.net/github-audit-logs/audit.json?REPLACE_WITH_SAS_TOKEN
AZURE_AUDIT_SAS_START=2026-01-01T00:00:00Z
AZURE_AUDIT_SAS_EXPIRY=2026-12-31T23:59:59Z
AZURE_AUDIT_SAS_KIND=user_delegation
GITHUB_ENTERPRISE_SLUG=your-enterprise-slug
GITHUB_AUDIT_STREAM_ID=0000
