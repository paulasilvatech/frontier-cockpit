# Copy to $HOME/frontier-cockpit/local-otel/azure/.env after deployment.
# deploy.sh writes these values automatically when the deployment succeeds.
# Override these deployment variables before deploy.sh for customer environments.
AZURE_RESOURCE_GROUP=rg-agentobs-dev-eus-001
AZURE_LOCATION=eastus
AZURE_WORKLOAD=agentobs
AZURE_ENVIRONMENT_NAME=dev
AZURE_REGION_ABBR=eus
AZURE_INSTANCE=001
AZURE_COLLECTOR_MIN_REPLICAS=1
AZURE_COLLECTOR_MAX_REPLICAS=3
AZURE_OTLP_ENDPOINT=https://ca-otelcol-dev-eus-001.example.azurecontainerapps.io
AZURE_OTLP_TOKEN=replace-with-generated-token
