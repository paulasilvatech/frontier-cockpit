# Frontier Cockpit Local - workshop participant identity
#
# Copy this file to workshop.env and edit the values. The workshop.env file is
# local-only and gitignored, so each participant keeps their own identity.
#
#   cp local-otel/workshop.env.example local-otel/workshop.env
#
# These values only label the local dashboard chrome at http://localhost:3300.
# They are NOT sent to Azure and are NOT official GitHub billing identity.
# If you leave a value empty, the dashboard falls back to a generic default.

# Shown as the main name in the dashboard chrome.
FRONTIER_PARTICIPANT_NAME="Workshop Participant"

# Shown next to the name, for example Developer, Tech Lead, Platform Engineer.
FRONTIER_PARTICIPANT_ROLE="Developer"

# Optional. Used only for local display.
FRONTIER_PARTICIPANT_EMAIL=""

# Optional team label, for example Platform Engineering.
FRONTIER_PARTICIPANT_TEAM=""

# Optional customer or organization label for the workshop.
FRONTIER_CUSTOMER_NAME=""

# Optional. Override the dashboard title and browser tab title.
FRONTIER_DASHBOARD_TITLE="Frontier Cockpit Local"

# GitHub Copilot plan and local AI Credits budget configuration.
# These drive the Credits budget panel, the plan comparison, and the Planner
# view. Under usage-based billing (since June 1, 2026) every Copilot plan
# includes a monthly allowance of GitHub AI Credits (1 credit = US$0.01) that
# resets on the 1st of each month (UTC) and does not roll over. Confirm current
# values in GitHub Docs, because they can change. This dashboard remains a
# local estimate, not official billing.
#
# Supported plans: free, pro, pro+, max, business, enterprise.
# Leave the monthly allowance blank to derive it from plan and seat count.
FRONTIER_COPILOT_PLAN="business"
FRONTIER_COPILOT_SEATS="1"
FRONTIER_AI_CREDITS_USE_PROMO="false"
FRONTIER_AI_CREDITS_MONTHLY_ALLOWANCE=""

# Reference values from GitHub Docs at the time this template was authored:
# - Pro (US$10/mo): 1,500 AI Credits (1,000 base + 500 flex allotment).
# - Pro+ (US$39/mo): 7,000 AI Credits (3,900 base + 3,100 flex).
# - Max (US$100/mo): 20,000 AI Credits (10,000 base + 10,000 flex).
# - Business (US$19/user/mo): 1,900 AI Credits per user, no flex.
# - Enterprise (US$39/user/mo): 3,900 AI Credits per user, no flex.
# - Free: auto model selection only; allowance not published, treated as 0.
# - Promotional Jun 1 to Sep 1, 2026 for existing Business/Enterprise
#   customers: 3,000 (Business) and 7,000 (Enterprise) per user per month.
#   Enable with FRONTIER_AI_CREDITS_USE_PROMO=true only if you qualify; the
#   cockpit automatically falls back to standard values after the window ends.
#   The window itself is configurable via FRONTIER_AI_CREDITS_PROMO_START/_END.
# - Auto model selection is billed with a 10% discount on model costs on paid
#   plans (AUTO_MODEL_SELECTION_DISCOUNT to override the local assumption).
#
# All alert thresholds (THRESHOLD_*) and coaching/planner weights (COACH_*,
# PLANNER_*) can also be set here; the Settings view lists every variable.
