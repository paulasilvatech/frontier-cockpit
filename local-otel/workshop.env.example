# Frontier Developer Cockpit - workshop participant identity
#
# Copy this file to workshop.env and edit the values. The workshop.env file is
# local-only and gitignored, so each participant keeps their own identity.
#
#   cp local-otel/workshop.env.example local-otel/workshop.env
#
# These values only label the local dashboard chrome at http://localhost:3300.
# They are NOT sent to Azure and are NOT official GitHub billing identity.
# If you leave a value empty, the dashboard falls back to a generic default.

# Shown as the main name in the dashboard chrome.
FRONTIER_PARTICIPANT_NAME="Workshop Participant"

# Shown next to the name, for example Developer, Tech Lead, Platform Engineer.
FRONTIER_PARTICIPANT_ROLE="Developer"

# Optional. Used only for local display.
FRONTIER_PARTICIPANT_EMAIL=""

# Optional team label, for example Platform Engineering.
FRONTIER_PARTICIPANT_TEAM=""

# Optional customer or organization label for the workshop.
FRONTIER_CUSTOMER_NAME=""

# Optional. Override the dashboard title and browser tab title.
FRONTIER_DASHBOARD_TITLE="Frontier Developer Cockpit"

# GitHub Copilot plan and local AI Credits budget configuration.
# These drive the Credits view budget panel. Under usage-based billing, Copilot
# Business and Enterprise usage is measured in GitHub AI Credits. Current docs
# list standard monthly credits per user and a promotional June-Sep 2026 amount
# for existing customers. Confirm current values in GitHub Docs, because they
# can change. This dashboard remains a local estimate, not official billing.
FRONTIER_COPILOT_PLAN="business"
FRONTIER_COPILOT_SEATS="1"
FRONTIER_AI_CREDITS_USE_PROMO="true"
FRONTIER_AI_CREDITS_MONTHLY_ALLOWANCE="3000"

# Reference values from GitHub Docs at the time this template was authored:
# - Business standard: 1,900 AI Credits per user per month.
# - Enterprise standard: 3,900 AI Credits per user per month.
# - Promotional June-Sep 2026 for existing customers: Business 3,000 and
#   Enterprise 7,000 AI Credits per user per month.
