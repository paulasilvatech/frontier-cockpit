  "panels": [
    {
      "type": "text",
      "title": "Start here",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "mode": "markdown",
        "content": "# Frontier Developer Cockpit\n\nThis is the local home for GitHub Copilot and agentic development telemetry. Use it to confirm the local stack is producing data, then drill into real workspace sessions, context behavior, model labels, tool calls, data quality, and coaching views. Local telemetry is operational telemetry, not official billing or adoption reporting."
      }
    },
    {
      "type": "stat",
      "title": "Registered workspaces",
      "description": "Friendly workspace registry emitted by register-workspace.sh. Registry rows are metadata, not usage volume.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-local"
          },
          "expr": "count(max_over_time(copilot_workspace_registry_ratio[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Real workspace sessions",
      "description": "Materialized traces with repository attribution. These are operational telemetry sessions, not official usage metrics.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-local"
          },
          "expr": "count(max_over_time(copilot_real_session_input_tokens_ratio{usage_scope=\"workspace_real\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "gauge",
      "title": "Peak context health",
      "description": "Highest context-window utilization across materialized real workspace sessions.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-local"
          },
          "expr": "max(max_over_time(copilot_real_session_context_utilization_pct_ratio{usage_scope=\"workspace_real\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "stat",
      "title": "Operational AIU",
      "description": "Runtime-reported AIU from local telemetry. This is not official billing.",
