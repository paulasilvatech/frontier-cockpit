            "renameByName": {
              "Value": "Observed (1/0)",
              "signal_type": "Signal type",
              "signal_name": "Signal",
              "status": "Status",
              "meaning": "Meaning"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
