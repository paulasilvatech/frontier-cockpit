    {
      "id": 5,
      "type": "table",
      "title": "Coverage matrix, observed vs not observed yet",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time(copilot_otel_coverage_status_ratio[$__range])",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-local"
          }
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "collector_instance": true,
              "exported_job": true,
              "otel_scope_name": true,
              "service_name": true,
              "service_version": true
